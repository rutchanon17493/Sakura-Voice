# Copy this file to .env and fill in your keys

# Audio input device index (optional)
# Run: python run.py --list-devices  to see all available microphone indices
# Leave unset to use the system default microphone
# AUDIO_INPUT_DEVICE=1

# NVIDIA NIM API Key (for local agent)
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# Sarvam AI API Key (for sarvam agent)
SARVAM_API_KEY=your_sarvam_api_key_here

# System prompt for the assistant
SYSTEM_PROMPT="You are Sakura, an advanced AI voice assistant. Reply concisely."

# Max conversation turns kept in LLM context (user+assistant pairs).
# Prevents context overflow in long conversations. Default: 20.
MAX_HISTORY_TURNS=20

# Sarvam language code (default: hi-IN)
# Run  python run.py --list-languages  to see all 23 options
SARVAM_LANGUAGE=hi-IN

# Sarvam TTS speaker voice (bulbul:v3 has 38 voices)
# NOTE: Speaker names must be lowercase for the Bulbul v3 API.
# Options: shubh, priya, rahul, neha, ritu, kavya, aditya, simran ...
SARVAM_SPEAKER=shubh

# ── Indic Agent (fully local, no API keys needed) ──────────────
# Starting language (run: python run.py --list-indic-languages to see all 17)
INDIC_LANGUAGE=hi-IN

# Ollama LLM model — must be pulled first: ollama pull qwen2.5:7b
# Lighter alternative: qwen2.5:3b  (~2 GB, less accurate on Indic)
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
# ───────────────────────────────────────────────────────────────
